# Spanner Configuration
# Copy this file to .env and customize:
#   cp .env.example .env
# Then run: ./bin/setup

# Required: Database password (auto-generated by setup script)
DB_PASSWORD=

# Required: Rails secret key base (auto-generated by setup script)
SECRET_KEY_BASE=

# Required: iron-session cookie secret (auto-generated by setup script)
CLIENT_SECRET=

# Required: Public URL for email links
WEB_URL=http://localhost:3000

# Email (SMTP) — optional, configured by setup script
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@localhost

# Webhook — optional, configured by setup script
NOTIFICATION_WEBHOOK_URL=
