# Required: Secret for iron-session cookie encryption
# Generate with: openssl rand -base64 32
CLIENT_SECRET=your-secret-key-here

# Required: URL of the API backend
API_URL=http://localhost:3001

# Sentry DSN for error tracking
PUBLIC_SENTRY_DSN=

# Set to 'false' for plain-HTTP local testing (default: true)
USE_SECURE_COOKIE=false

# Set to 'true' if email (Postmark or SMTP) is configured on the API.
# Controls whether the magic link button is shown on the login page.
PUBLIC_EMAIL_ENABLED=true
