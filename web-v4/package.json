		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@vitest/browser-playwright": "^4.1.8",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@fontsource/lato": "^5.2.7",
		"camelcase-keys": "^10.0.2",
		"date-fns": "^4.4.0",
