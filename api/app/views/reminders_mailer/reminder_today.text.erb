You wanted to be reminded about some things today.

<% @reminders.group_by(&:vehicle).each do |vehicle, reminders| %>
  <%= vehicle.name %>
  <%= vehicle_url(vehicle) %>

  <% reminders.each do |reminder| %>
    * <%= reminder.notes %>
  <% end %>

  Manage notifications for <%= vehicle.name %>: <%= web_preferences_url(token: @user.account_token, vehicle_id: vehicle.id) %>

<% end %>

